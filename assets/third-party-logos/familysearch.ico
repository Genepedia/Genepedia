      (function() {
        var injHF = document.createElement('script'),
          frontURL = window.location.protocol + '//' + window.location.host; //https://css-tricks.com/snippets/javascript/get-url-and-url-parts-in-javascript/

        if (frontURL.indexOf('familysearch') === -1 || frontURL.indexOf("notfound") !== -1){
          frontURL = 'https://www.familysearch.org';//looking at page from cdn, cdn's alias or local machine, use prod url
        }

        injHF.async = true;
        injHF.src = frontURL + '/header/hf.js?fullwidth=true';
        document.getElementsByTagName("head")[0].appendChild(injHF);
      })();
    </script>
