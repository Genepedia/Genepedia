        background-position: top center;
        background-repeat: no-repeat;
        background-size: contain;
        width: 390px;
        height: 210px;
        margin-right: auto;
        margin-left: auto;
        box-sizing: border-box;
        margin-top: 90px;
        margin-bottom: 43px; 
      }
      section.not-found-wrapper {
        max-width: 470px;
        padding-right: 15px;
        padding-left: 15px;
        margin-right: auto;
        margin-left: auto;
        text-align: center;
        font-size: 16px;
        line-height: 1.5;
        font-family: verdana, sans-serif;
      }
      .not-found-wrapper h1 {
        font-size: 2.125em;
        line-height: 1.2;
        margin-bottom: 10px;
      }
      .not-found-wrapper .main-text {
        line-height: 1.8;
        margin-bottom: 50px;
      }
      .not-found-wrapper strong {
        font-size: 0.875em;
      }
      .not-found-wrapper a {
        color: #177c9c;
        text-decoration: none;
      }
      .not-found-wrapper a:visited {
        color: #bd0057;
      }
      .not-found-wrapper a:hover {
        text-decoration: underline;
      }
      .not-found-wrapper ul {
        list-style-type: none;
        padding: 0;
        margin-bottom: 100px;
      }
      .not-found-wrapper ul li {
        margin-bottom: 14px;
      }
      .not-found-wrapper ul li.li-with-button {
        margin-bottom: 24px;
        margin-top: 20px;
      }
      .not-found-wrapper button {
        color: #177c9c;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        -webkit-touch-callout: none;
        cursor: pointer;
        display: inline-block;
        font-size: 14px;
        font-weight: normal;
        line-height: 1;
        padding: 11px 16px;
        position: relative;
        text-decoration: none;
        user-select: none;
        vertical-align: middle;
        white-space: nowrap;
        background: transparent;
        border: 0;
        border-radius: 4px;
        text-transform: uppercase;
        box-shadow: none;
        overflow: hidden;
        transform: perspective(80px) translateZ(0px);
        -webkit-backface-visibility: hidden;
        will-change: transform;
        transition: background-color 0.3s, transform 0.1s;
        height: 36px;
        box-sizing: border-box;
        border: 1px solid #177c9c;
      }
      button:focus {
        outline: none;
        background: #E9F7FC;
        transform: perspective(80px) translateZ(3px);
      }
      button:hover {
        transform: perspective(80px) translateZ(5px);
        text-decoration: none;
        background: #F2FAFD;
      }
      button:active {
        transform: perspective(80px) translateZ(0px);
      }
      .not-found-wrapper .small {
        font-size: 0.875em;
      }
      .locale-ja .not-found-wrapper ul li {
        max-width: 460px;
        margin-right: auto;
        margin-left: auto;
      }
      @media screen and (max-width: 800px) {
        .not-found-wrapper h1 {
          font-size: 1.75em;
        }
      }
      @media screen and (max-width: 425px) {
        .not-found-image {
          height: 0;
          width: 100%;
          padding-top: 56.476684%;
        }
      }

    </style>
