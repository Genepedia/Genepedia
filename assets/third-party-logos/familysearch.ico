        var readCookie = function(name) {
          var value = "; " + document.cookie;
          var parts = value.split("; " + name + "=");
          if (parts.length == 2) return parts.pop().split(";").shift();
        };
        var computeLocale = function(lang) {
          var regex = /^\w{2}/;
          lang = (typeof lang !== 'string' || !lang) ? navigator.language : lang;
          var matches = lang.match(regex);
          if (matches && matches.length) {
            return matches[0];
          }
          return 'en';
        };
        var getCountryCode = function() {
          var navLanguage = (navigator.languages) ? navigator.languages[0] : navigator.language;
          return readCookie('fslanguage') || computeLocale(navLanguage);
        };
        var addString = function(element) {
          var cc = getCountryCode();
          var localeKey = element.getAttribute("i18n");
          element.textContent = locale[cc] ? locale[cc][localeKey] : locale['en'][localeKey];
        };
        elementList.forEach.call(document.querySelectorAll("[i18n]"), addString);
      })();
    </script>
